<!DOCTYPE html>
<html>
<head>
  <title>ASLAB Prototype</title>
  <style>
    body { font-family: Arial; padding: 20px; }
    table { border-collapse: collapse; width: 100%; margin-top: 20px;}
    th, td { border: 1px solid #ccc; padding: 8px; text-align: center;}
    .keep { background: #c8f7c5; }
    .revise { background: #fff3cd; }
    .remove { background: #f8d7da; }
  </style>
</head>
<body>

<h1>ASLAB Prototype</h1>

<p>Answer Key (comma separated):</p>
<input id="answerKey" value="A,B,C,D,A">

<p>Student Responses (one per line, comma separated):</p>
<textarea id="responses" rows="6" cols="50">
A,B,C,D,A
A,B,C,C,A
A,B,D,D,A
B,B,C,D,A
</textarea>

<br><br>
<button onclick="analyze()">Analyze</button>

<div id="output"></div>

<script>
function analyze() {
  let key = document.getElementById("answerKey").value.split(",");
  let responses = document.getElementById("responses").value.trim().split("\n")
                  .map(r => r.split(","));

  let totalStudents = responses.length;
  let questions = key.length;

  let scores = responses.map(r =>
    r.reduce((acc, ans, i) => acc + (ans === key[i] ? 1 : 0), 0)
  );

  // sort students by score
  let sorted = responses.map((r, i) => ({r, score: scores[i]}))
                        .sort((a,b) => b.score - a.score);

  let groupSize = Math.floor(totalStudents * 0.27) || 1;
  let topGroup = sorted.slice(0, groupSize);
  let bottomGroup = sorted.slice(-groupSize);

  let table = `<table>
  <tr><th>Q#</th><th>Difficulty</th><th>Discrimination</th><th>Verdict</th><th>Recommendation</th></tr>`;

  for (let i = 0; i < questions; i++) {
    let correct = responses.filter(r => r[i] === key[i]).length;
    let difficulty = correct / totalStudents;

    let topCorrect = topGroup.filter(s => s.r[i] === key[i]).length;
    let bottomCorrect = bottomGroup.filter(s => s.r[i] === key[i]).length;

    let discrimination = (topCorrect - bottomCorrect) / groupSize;

    let verdict = "";
    let rec = "";
    let className = "";

    if (discrimination < 0) {
      verdict = "Problematic";
      rec = "Remove";
      className = "remove";
    } else if (discrimination < 0.2) {
      verdict = "Weak";
      rec = "Revise";
      className = "revise";
    } else {
      verdict = "Strong";
      rec = "Keep";
      className = "keep";
    }

    table += `<tr class="${className}">
      <td>${i+1}</td>
      <td>${difficulty.toFixed(2)}</td>
      <td>${discrimination.toFixed(2)}</td>
      <td>${verdict}</td>
      <td>${rec}</td>
    </tr>`;
  }

  table += "</table>";

  document.getElementById("output").innerHTML = table;
}
</script>

</body>
</html>
